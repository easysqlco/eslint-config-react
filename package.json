{
  "name": "@easysql/eslint-config-react",
  "version": "0.0.3",
  "description": "Shared React ESLint flat config layer for EasySQL packages",
  "author": "EasySQL",
  "license": "MIT",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "AGENTS.md",
    "index.d.ts",
    "index.js",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/easysqlco/eslint-config-react.git"
  },
  "homepage": "https://github.com/easysqlco/eslint-config-react#readme",
  "bugs": {
    "url": "https://github.com/easysqlco/eslint-config-react/issues"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "flat-config",
    "easysqlco",
    "react"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "test": "npm run validate",
    "validate": "npm run lint && npm run build && node ./scripts/validate-package.mjs"
  },
  "dependencies": {
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0"
  },
  "devDependencies": {
    "@easysql/eslint-config": "file:../eslint-config",
    "eslint": "^9.39.4",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "eslint": ">= 9.7 < 10"
  },
  "publishConfig": {
    "access": "public"
  }
}
